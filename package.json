{
  "name": "supplementstack",
  "version": "1.0.0",
  "description": "Supplement Stack Management Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=supplementstack-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build && echo 'Build completed successfully for Cloudflare Pages deployment'",
    "build:fast": "node build-optimized.js && echo 'Performance-optimized build completed'",
    "build:analyze": "npm run build:fast && echo 'Build analysis available in dist/performance-report.json'",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build:fast && wrangler pages deploy dist",
    "deploy:prod": "npm run build:fast && wrangler pages deploy dist --project-name supplementstack",
    "deploy:quick": "./deploy-cloudflare.sh",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl http://localhost:3000",
    "db:migrate:local": "wrangler d1 migrations apply supplementstack-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply supplementstack-production",
    "db:seed": "wrangler d1 execute supplementstack-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console:local": "wrangler d1 execute supplementstack-production --local",
    "db:console:prod": "wrangler d1 execute supplementstack-production"
  },
  "dependencies": {
    "form-data": "^4.0.4",
    "hono": "^4.0.0",
    "pm2": "^6.0.10"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250705.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wrangler": "^3.78.0"
  }
}
